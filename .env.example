# MyLibrary — Environment Variables
# Copy this to .env and fill in your values

SECRET_KEY="your_super_secret_flask_key_here"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# Email (Gmail SMTP — use App Password)
MAIL_EMAIL="your-email@gmail.com"
MAIL_PASSWORD="your-gmail-app-password"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"

# Cloudinary (free tier at cloudinary.com)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# OpenRouter AI (free tier at openrouter.ai)
OPENROUTER_API_KEY="sk-or-..."
